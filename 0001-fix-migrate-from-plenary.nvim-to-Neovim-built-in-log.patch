@@ -2,15 +2,8 @@ local M = {}
 
 M.spinner_manager = require("codecompanion-spinner.spinner-manager")
 M.log = require("codecompanion-spinner.log")
-
 M.opts = {
 	log_level = "info",
 }
 
-function M.setup(opts)
